{
  "name": "getsober",
  "version": "2.0.1",
  "description": "Sober: a shared rules-and-tools harness for Claude Code Pro and Codex Plus that cuts wasted AI quota.",
  "author": "donghoon <move-hoon@users.noreply.github.com>",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "sober": "bin/sober.js"
  },
  "files": [
    "bin/",
    "lib/",
    ".sober/",
    "project-template/",
    "install.sh",
    ".claude/README.md",
    ".claude/settings.json",
    ".claude/settings.local.example.json",
    ".codex/README.md",
    ".codex/AGENTS.md",
    ".codex/config.toml.example",
    ".agents/README.md",
    ".agents/skills/README.md",
    ".claudeignore",
    "README.md",
    "README.ko.md",
    "CONTRIBUTING.md",
    "docs/USER-MANUAL.md",
    "docs/USER-MANUAL.ko.md",
    "docs/adr/",
    "LICENSE"
  ],
  "scripts": {
    "help": "node bin/sober.js --help",
    "setup": "node bin/sober.js setup",
